{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "gender": { "type": "string", "enum": ["men", "women", "unisex"] },
        "basePhotoBase64": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["gender", "createdAt", "updatedAt"]
    },
    "WardrobeItem": {
      "title": "WardrobeItem",
      "description": "An extracted and normalized clothing item",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string", "enum": ["top", "bottom", "fullbody"] },
        "imageBase64": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "category", "imageBase64", "createdAt"]
    },
    "Outfit": {
      "title": "Outfit",
      "description": "A saved combination of wardrobe items",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "resultImageBase64": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "resultImageBase64", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profile."
    },
    "wardrobeItems/{itemId}": {
      "schema": { "$ref": "#/entities/WardrobeItem" },
      "description": "Stores individual extracted clothing items."
    },
    "outfits/{outfitId}": {
      "schema": { "$ref": "#/entities/Outfit" },
      "description": "Stores saved outfit combos."
    }
  }
}
